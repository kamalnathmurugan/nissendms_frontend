# ============================================================================
# FRONTEND (SPA) Entra app — used for SSO login in the browser (Phase B+).
# NOT the backend app. NO client secret here (SPAs must not hold secrets).
# Only needed once we implement SSO; safe to leave unset until then.
# Copy to `.env` and fill in when wiring SSO.
# ============================================================================

# The FRONTEND app registration's Application (client) ID
VITE_AZURE_CLIENT_ID=a62b9fed-652f-45bf-b0be-003a24675453

# Your directory (tenant) ID — same tenant as the backend app
VITE_AZURE_TENANT_ID=866aa516-5b6a-4088-9306-cb76327df469

# Redirect URI registered on the FRONTEND app (SPA platform).
# For local dev this is the Vite origin.
VITE_REDIRECT_URI=http://localhost:5173

# Base URL of our backend API (leave as /api to use the Vite dev proxy)
VITE_API_BASE=/api
